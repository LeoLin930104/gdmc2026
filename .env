# Required: your API key.
LLM_API_KEY=

# Optional: any OpenAI-compatible endpoint. Defaults shown below.
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_MODEL=gpt-4o-mini

# Optional: which offline fallback story to use when no API key / LLM is
# available. 1 = Emberwell, 2 = Saltmarrow, 3 = Thornhallow. Default is 1.
LLM_FALLBACK_STORY=1
