# REQUIRED — your API key. Without it, the narrative falls back to authored
# offline content (no live generation).
LLM_API_KEY=

# OPTIONAL — the API base URL. Default: OpenAI.
LLM_API_BASE_URL=https://api.openai.com/v1

# OPTIONAL — the model id. Default: gpt-4o-mini.
LLM_API_MODEL=gpt-4o-mini

# OPTIONAL — offline fallback lore variant (1, 2, or 3). 
NARRATIVE_FALLBACK_VARIANT=1
